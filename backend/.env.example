# Kortana Backend Configuration

# Server
PORT=4002
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=*

# Creditcoin EVM Testnet
NETWORK=creditcoin-testnet
CHAIN_ID=102031
RPC_URL=https://rpc.cc3-testnet.creditcoin.network

# Your EVM address that receives payments (0x... format)
SERVER_ADDRESS=0x0000000000000000000000000000000000000000

# Native token
TOKEN=CTC

# LLM APIs
GROQ_API_KEY=
GEMINI_API_KEY=

# Agent private key (EVM hex, no 0x prefix)
AGENT_PRIVATE_KEY=
