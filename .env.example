# ═══════════════════════════════════════════════════════════════
# Kortana — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Backend Server ──────────────────────────────────────────────
PORT=4002
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=*

# Creditcoin EVM Testnet
NETWORK=creditcoin-testnet
CHAIN_ID=102031
RPC_URL=https://rpc.cc3-testnet.creditcoin.network

# Your EVM address that receives payments (0x... format)
# Get testnet CTC from Creditcoin faucet
SERVER_ADDRESS=0x0000000000000000000000000000000000000000

# Native token
TOKEN=CTC

# ── Agent Client ────────────────────────────────────────────────
# Private key for the agent wallet (EVM hex, NO 0x prefix)
AGENT_PRIVATE_KEY=

# Backend server URL the agent will call
AGENT_SERVER_URL=http://localhost:4002

# ── LLM APIs ────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
